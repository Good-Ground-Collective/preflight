{
  "name": "eslint-plugin-preflight",
  "version": "0.1.0",
  "description": "ESLint plugin enforcing the coding charter — nit-level review feedback, caught before the PR",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/good-ground-collective/preflight.git"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsup"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": ">=9.0.0",
    "eslint-plugin-import-x": ">=4.17.0",
    "eslint-plugin-unicorn": ">=56.0.0",
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.64.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@typescript-eslint/rule-tester": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "jiti": "^2.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
